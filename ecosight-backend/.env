# =============================================
# EcoSight Backend - Environment Configuration
# =============================================

# MongoDB Atlas
MONGODB_URI=mongodb+srv://pprave_db_user:@ecosightdb.xxxqpts.mongodb.net/?appName=ecosight
MONGODB_DB_NAME=ecosight

# Clerk (for verifying JWT tokens from the frontend)
CLERK_SECRET_KEY=sk_test_ICHyycu9YGp7vp

# CORS - Frontend URL
FRONTEND_URL=http://localhost:3000

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Model paths (place your .pt files in models_dir/)
OBJECT_MODEL_PATH=models_dir/best.pt
HUMAN_MODEL_PATH=models_dir/yolov8n.pt

# Bin capacity thresholds (total item count per class to consider bin "full")
# The system computes a weighted fill % based on these per-class capacities
PLASTIC_CAPACITY=100
METAL_CAPACITY=50
GLASS_CAPACITY=40
PAPER_CAPACITY=80
BIO_HAZARD_CAPACITY=30

# Contamination detection confidence threshold (0.0 - 1.0)
CONTAMINATION_CONFIDENCE_THRESHOLD=0.75

# Face blur: always on when human model detects a face
ENABLE_FACE_BLUR=true

# Upload directory
UPLOAD_DIR=uploads
